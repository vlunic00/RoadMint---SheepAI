{
  "expo": {
    "name": "SheepAI Road Assessor",
    "slug": "sheepai-road-assessor",
    "version": "0.1.0",
    "sdkVersion": "54.0.0",
    "runtimeVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "plugins": [
      [
        "@reactvision/react-viro",
        {
          "provider": "none",
          "android": {
            "xRMode": [
              "AR"
            ]
          },
          "ios": {
            "cameraUsagePermission": "Allow SheepAI to scan the road surface for potholes and pavement damage.",
            "microphoneUsagePermission": "Allow SheepAI to record road assessment clips."
          }
        }
      ],
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow SheepAI to scan the road surface for potholes and pavement damage.",
        "NSMicrophoneUsageDescription": "Allow SheepAI to record road assessment clips."
      }
    },
    "android": {
      "permissions": [
        "CAMERA"
      ],
      "package": "com.sheepai.roadassessor"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
